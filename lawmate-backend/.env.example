PORT=5000
MONGODB_URI=mongodb://localhost:27017/lawmate
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
NODE_ENV=development
GROQ_API_KEY=your_groq_api_key_here
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLIENT_URL=http://localhost:5173

# --- Email Configuration (Nodemailer) ---

# The hostname of your SMTP server (e.g., smtp.gmail.com for Gmail, smtp.sendgrid.net for SendGrid)
# If left blank during development, the system will auto-generate an Ethereal Test Account
EMAIL_HOST=smtp.gmail.com

# The port used by your SMTP server (usually 587 for TLS or 465 for SSL)
EMAIL_PORT=587

# Your email address used for authentication
EMAIL_USER=your_email@gmail.com

# Your email password. 
# ATTENTION GMAIL USERS: Do NOT use your normal login password. 
# You MUST generate an "App Password" from your Google Account Security settings.
# Ensure 2-Step Verification is turned on, search for "App Passwords", and create one for "LawMate".
EMAIL_PASS=your_16_character_app_password

# The completely formatted string showing who the email is from (Optional, defaults to noreply@lawmate.com)
EMAIL_FROM="LawMate Support <noreply@lawmate.com>"
